# ==========================================================================
# DeepForense — Variables de entorno (ejemplo)
# Copiar este archivo a ".env" y completar los valores reales.
# NUNCA subir el ".env" real al repositorio.
# ==========================================================================

# --- PostgreSQL (auth-service) -------------------------------------------
POSTGRES_DB=deepforense_auth
POSTGRES_USER=deepforense
POSTGRES_PASSWORD=changeme

# --- MongoDB (forensic-api / forensic-worker) ----------------------------
MONGO_ROOT_USER=deepforense
MONGO_ROOT_PASSWORD=changeme
MONGO_DB=deepforense_forensic

# --- MinIO (almacenamiento de artifacts) ---------------------------------
MINIO_ROOT_USER=deepforense
MINIO_ROOT_PASSWORD=changeme123
MINIO_BUCKET=deepforense-artifacts

# --- JWT (auth-service) ---------------------------------------------------
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRATION_MS=3600000

# --- Scraping de URLs (forensic-api, Capa 1) ------------------------------
SCRAPFLY_API_KEY=

# --- IA (forensic-worker, Capa 2) -----------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_OCR_DEEPINFRA_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Reglas de negocio (forensic-worker) ----------------------------------
MAX_IMAGES_PER_JOB=5
BENFORD_MIN_AMOUNT_COUNT=15
CONSOLIDATION_POLICY=worst_case_dominates

# --- Frontend --------------------------------------------------------------
# En local (target dev) se lee en runtime. En main (target prod) se pasa como
# build-arg y queda fijo dentro del bundle: usar la URL pública real de Kong
# (ej. https://api.deepforense.com), nunca localhost.
VITE_API_BASE_URL=http://localhost:8000
